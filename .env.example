# ============================================================================
# Job Search MCP — environment variables (ALL OPTIONAL)
#
# Copy to `.env.local` for local dev, or set these as Vercel project env vars.
# With NONE of these set, the app runs in deterministic DEMO mode (no network,
# no secrets). Add a single API key to auto-upgrade to LIVE AI mode.
# ============================================================================

# --- Provider selection ------------------------------------------------------
# auto (default) picks a provider from whichever key below is present, in this
# order: groq > anthropic > openai > huggingface. Or pin one: groq | anthropic |
# openai | huggingface | demo.
# LLM_PROVIDER=auto

# --- API keys (set at most one to enable live AI) ----------------------------
# GROQ_API_KEY=gsk_...          # fast & free, OpenAI-compatible (recommended)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# HF_TOKEN=hf_...

# --- Generation tuning (safe defaults applied if unset) ----------------------
# LLM_MODEL=            # provider default used if unset (e.g. llama-3.3-70b-versatile, gpt-4o-mini)
# MAX_TOKENS=600
# TEMPERATURE=0.7

# --- Caching (OPTIONAL) ------------------------------------------------------
# Without these, an in-process cache is used (per serverless instance). Set a
# Vercel KV / Upstash Redis store to share the cache across all instances and
# make warm searches sub-second fleet-wide.
# KV_REST_API_URL=https://<your-store>.upstash.io
# KV_REST_API_TOKEN=...

# Protects the /api/cron/revalidate cache-warming endpoint (Vercel Cron sends
# this automatically). If unset, the endpoint is open.
# CRON_SECRET=...
